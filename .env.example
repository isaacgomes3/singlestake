# Servidor: WebSocket Pragmatic Play (roleta ao vivo → /api/roulette/spins)
# Listar IDs de mesa para este casino: npm run dga:list-tables
ROULETTE_WS_URL=wss://dga.pragmaticplaylive.net/ws
ROULETTE_CASINO_ID=ppcdk00000005148
ROULETTE_TABLE_ID=234
# Várias mesas: vírgula ou espaço. Cada ID = 1 WebSocket. Histórico ao vivo fica em `roulette.liveTableHistory.{id}` por mesa; o 1.º ID continua a alimentar Ruas/espelho.
# Se esta linha não existir ou estiver vazia, usa apenas ROULETTE_TABLE_ID acima.
ROULETTE_TABLE_IDS=234,227,206,203,230,205,201,224,221,233,237
# Chave DGA da «Roulette Macao» no lobby (por defeito 206 neste casino; outro operador: npm run dga:inspect-table-names). Ver docs/roulette-macao-dga.md
# ROULETTE_MACAO_TABLE_ID=206
# VITE_ROULETTE_MACAO_TABLE_ID=206
ROULETTE_CURRENCY=BRL
# ms após "available" antes de enviar "subscribe" se a API não mandar tableKey reconhecível (default 400)
# ROULETTE_SUBSCRIBE_DELAY_MS=400
# s após o último EventSource fechar antes de desligar o WS Pragmatic (default 20s; em dev reduz reconexões)
# ROULETTE_HUB_IDLE_SHUTDOWN_MS=20000
# Valor negativo (ex. -1) = nunca desligar o WS por falta de clientes SSE (útil para depurar “API parou”)
# ROULETTE_HUB_IDLE_SHUTDOWN_MS=-1

# Estratégia global (sinais + histórico partilhados entre dispositivos). Servidor Node grava em data/roulette-strategy-global.json
# ROULETTE_STRATEGY_GLOBAL_PATH=./data/roulette-strategy-global.json
# Cliente: desactivar com VITE_ROULETTE_STRATEGY_GLOBAL=0 (por defeito activo quando a API ao vivo está ligada)

# Cliente (Vite): URLs do jogo por mesa para a página /casino-mesa (iframe + HUD). JSON com ids Pragmatic.
# Ex.: VITE_CASINO_TABLE_EMBED_URLS={"225":"https://operador.example/game/..."}
# VITE_CASINO_TABLE_EMBED_URLS=
# Recorte da moldura do iframe (% da área visível; também ajustável na UI «Moldura»).
# VITE_CASINO_EMBED_CROP_TOP=11
# VITE_CASINO_EMBED_CROP_BOTTOM=8.5
# VITE_CASINO_EMBED_CROP_LEFT=0
# VITE_CASINO_EMBED_CROP_RIGHT=0

# Opcional: logs no terminal do servidor
# DEBUG_ROULETTE_WS=1
# Cada mensagem JSON bruta do WebSocket (handshake + giros)
# DEBUG_ROULETTE_WS_MSG=1
