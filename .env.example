# Servidor: WebSocket Pragmatic Play (roleta ao vivo → /api/roulette/spins)
# Listar IDs de mesa para este casino: npm run dga:list-tables
ROULETTE_WS_URL=wss://dga.pragmaticplaylive.net/ws
ROULETTE_CASINO_ID=ppcdk00000005148
ROULETTE_TABLE_ID=234
# Várias mesas: vírgula ou espaço. Cada ID = 1 WebSocket. Histórico ao vivo fica em `roulette.liveTableHistory.{id}` por mesa; o 1.º ID continua a alimentar Ruas/espelho.
# Se esta linha não existir ou estiver vazia, usa apenas ROULETTE_TABLE_ID acima.
ROULETTE_TABLE_IDS=234,227,206,203,230,205,201,224,221,233,213,237
# Chave DGA da «Roulette Macao» no lobby (por defeito 206 neste casino; outro operador: npm run dga:inspect-table-names). Ver docs/roulette-macao-dga.md
# ROULETTE_MACAO_TABLE_ID=206
# VITE_ROULETTE_MACAO_TABLE_ID=206
ROULETTE_CURRENCY=BRL
# ms após "available" antes de enviar "subscribe" se a API não mandar tableKey reconhecível (default 400)
# ROULETTE_SUBSCRIBE_DELAY_MS=400
# s após o último EventSource fechar antes de desligar o WS Pragmatic (default 20s; em dev reduz reconexões)
# ROULETTE_HUB_IDLE_SHUTDOWN_MS=20000
# Valor negativo (ex. -1) = nunca desligar o WS por falta de clientes SSE (útil para depurar “API parou”)
# ROULETTE_HUB_IDLE_SHUTDOWN_MS=-1

# Estratégia global (sinais + histórico partilhados entre dispositivos). Servidor Node grava em data/roulette-strategy-global.json
# ROULETTE_STRATEGY_GLOBAL_PATH=./data/roulette-strategy-global.json
# Simulação de automação (sala rotativa 1 fator) — corre no servidor, independente do browser
# ROULETTE_AUTOMATION_SIM_PATH=./data/roulette-automation-sim.json
# Cliente: desactivar com VITE_ROULETTE_STRATEGY_GLOBAL=0 (por defeito activo quando a API ao vivo está ligada)

# Sync extensão Chrome → servidor (visor + extrato + automação alinhados ao motor da extensão)
# Defina o mesmo segredo na config DGA da extensão (syncSecret) e reinicie PM2 após alterar.
# EXTENSION_SYNC_SECRET=altere-com-string-longa-aleatoria
# EXTENSION_SYNC_TTL_MS=45000

# Domínio de produção (referência; links usam o origin do pedido)
# PUBLIC_APP_URL=https://stake37.com.br
# Subdomínio só automação (sala rotativa, simulador, extensão) — ver deploy/env.automation.example
# PUBLIC_AUTOMATION_URL=https://auto.stake37.com.br
# VITE_AUTOMATION_PUBLIC_URL=https://auto.stake37.com.br
# APP_PROFILE=backoffice

# Base de dados (SQLite local por defeito; em produção use caminho absoluto na VPS)
# Sandbox local isolado: npm run setup:local → data/local/singlestake.db
DATABASE_URL=./data/singlestake.db
# Em desenvolvimento, ver também .env.development (carregado automaticamente com npm run dev).
# SESSION_SECRET=altere-em-producao-com-string-longa-aleatoria
# SEED_ADMIN_EMAIL=admin@singlestake.local
# SEED_ADMIN_PASSWORD=123456

# Cliente (Vite): URLs do jogo por mesa para a página /casino-mesa (iframe + HUD). JSON com ids DGA → URL do operador.
# A estratégia (Um Fator / sala rotativa) só indica a mesa; o provedor é configurado aqui (Playtech, Pragmatic, etc.).
# Ex. Playtech:  VITE_CASINO_TABLE_EMBED_URLS={"227":"https://br4.bet.br/play/playtech/roulette-1","203":"https://br4.bet.br/play/playtech/speed-roulette"}
# Ex. Pragmatic (sala rotativa br4.bet):
# VITE_CASINO_TABLE_EMBED_URLS={"237":"https://br4.bet.br/play/pragmatic/roleta-brasileira","227":"https://br4.bet.br/play/pragmatic/roulette-1","203":"https://br4.bet.br/play/pragmatic/speed-roulette-1","230":"https://br4.bet.br/play/pragmatic/roulette-3","201":"https://br4.bet.br/play/pragmatic/roulette-2-extra-time","206":"https://br4.bet.br/play/pragmatic/roulette-macao","213":"https://br4.bet.br/play/pragmatic/korean-roulette"}
# Operador ice.bet (dev local — ver também casinoEmbedIceDefaults.ts):
# VITE_CASINO_OPERATOR=ice
# VITE_CASINO_TABLE_EMBED_URLS={"227":"https://ice.bet.br/games/tag/roulette/rouletteazure-pragmaticexternal","203":"https://ice.bet.br/games/tag/roulette/speedroulette-pragmaticexternal","230":"https://ice.bet.br/games/tag/roulette/roulette10ruby-pragmaticexternal","201":"https://ice.bet.br/games/tag/roulette/liveroulettea-pragmaticexternal","206":"https://ice.bet.br/games/tag/roulette/roulettemacao-pragmaticexternal","237":"https://ice.bet.br/games/tag/roulette/brazilianroulette-pragmaticexternal","213":"https://ice.bet.br/games/tag/roulette/koreanroulette-pragmaticexternal"}
# French la Partage (28401) fora da automação — tapete diferente.
# VITE_CASINO_TABLE_EMBED_URLS=
# Recorte da moldura do iframe (% da área visível; também ajustável na UI «Moldura»).
# VITE_CASINO_EMBED_CROP_TOP=11
# VITE_CASINO_EMBED_CROP_BOTTOM=8.5
# VITE_CASINO_EMBED_CROP_LEFT=0
# VITE_CASINO_EMBED_CROP_RIGHT=0

# Opcional: logs no terminal do servidor
# DEBUG_ROULETTE_WS=1
# Cada mensagem JSON bruta do WebSocket (handshake + giros)
# DEBUG_ROULETTE_WS_MSG=1
