{
  "manifest_version": 3,
  "name": "Singlestake — Playtech Um Fator",
  "version": "1.4.4",
  "description": "Executa entradas Um Fator no operador Playtech/Pragmatic. Modos Demo (simulado) e Real (clique CDP na mesa).",
  "permissions": ["tabs", "storage", "scripting", "debugger", "windows"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content-bridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://*/*", "http://*/*"],
      "exclude_matches": [
        "http://localhost/*",
        "http://127.0.0.1/*",
        "https://localhost/*",
        "https://127.0.0.1/*",
        "https://roleta.poupexplay.com/*",
        "https://*.poupexplay.com/*",
        "https://br4.bet.br/*",
        "https://*.br4.bet.br/*",
        "https://*.bet.br/*",
        "https://singlestake.bet.br/*",
        "https://www.singlestake.bet.br/*",
        "https://stake37.com.br/*",
        "https://www.stake37.com.br/*"
      ],
      "js": ["content-casino.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Singlestake Playtech",
    "default_popup": "popup.html"
  }
}
