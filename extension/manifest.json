{
  "manifest_version": 3,
  "name": "Game Odds Glow — Sala Rotativa (aprendizagem)",
  "version": "0.2.0",
  "description": "Recebe sinais da Sala Rotativa e mapeia factores (ex. Ímpar) a apostas exteriores Pragmatic.",
  "permissions": ["tabs", "storage", "scripting"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost/*",
        "http://127.0.0.1/*",
        "https://roleta.poupexplay.com/*",
        "https://*.poupexplay.com/*"
      ],
      "js": ["content-app.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://*/*", "http://*/*"],
      "exclude_matches": [
        "http://localhost/*",
        "http://127.0.0.1/*",
        "https://roleta.poupexplay.com/*",
        "https://*.poupexplay.com/*"
      ],
      "js": ["content-casino.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "GOG Sala Rotativa",
    "default_popup": "popup.html"
  }
}
