# Copiado automaticamente por `npm run setup:local` → `.env.development.local`
# Sandbox isolado de produção — pode apagar e recriar com `npm run reset:local`
#
# O Vite carrega este ficheiro em `npm run dev` (ignorado pelo git via *.local).

NODE_ENV=development

# --- Sandbox local (nunca usar estes caminhos na VPS) ---
DATABASE_URL=./data/local/singlestake.db
ROULETTE_STRATEGY_GLOBAL_PATH=./data/local/roulette-strategy-global.json
ROULETTE_AUTOMATION_SIM_PATH=./data/local/roulette-automation-sim.json

# --- App ---
SESSION_SECRET=dev-local-singlestake-sandbox-not-for-production
PUBLIC_APP_URL=http://localhost:5173
APP_PROFILE=backoffice

# --- Admin demo (seed) ---
SEED_ADMIN_EMAIL=admin@singlestake.local
SEED_ADMIN_PASSWORD=123456
SEED_ADMIN_NAME=Admin Local

# --- Roleta ao vivo (mesmos IDs de demo; desligue com ROULETTE_TABLE_IDS= vazio) ---
ROULETTE_WS_URL=wss://dga.pragmaticplaylive.net/ws
ROULETTE_CASINO_ID=ppcdk00000005148
ROULETTE_TABLE_ID=234
ROULETTE_TABLE_IDS=234,227,206,203,230,201,213,237
ROULETTE_CURRENCY=BRL
ROULETTE_HUB_IDLE_SHUTDOWN_MS=-1

# --- Flags úteis em dev ---
# DEBUG_ROULETTE_WS=1
# VITE_ROULETTE_STRATEGY_GLOBAL=1
