{
  "name": "singlestake",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 5173",
    "dev:local": "npm run setup:local && npm run dev",
    "setup:local": "npx --yes tsx scripts/setup-local.ts",
    "reset:local": "npx --yes tsx scripts/reset-local.ts",
    "check:local": "npx --yes tsx scripts/check-local.ts",
    "seed:local-automation": "npx --yes tsx scripts/seed-local-automation.ts",
