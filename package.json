    "extension:copy-desktop": "node scripts/copy-extension-to-desktop.mjs",
    "extension:build": "npx --yes esbuild extension/strategy-entry.ts --bundle --format=iife --global-name=SinglestakeUmFator --outfile=extension/um-fator-engine.js --platform=browser --target=chrome110 --alias:@=./src",
