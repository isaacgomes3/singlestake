    "db:push": "drizzle-kit push",
    "db:migrate": "npx --yes tsx scripts/db-migrate.ts",
    "db:seed": "npx --yes tsx scripts/db-seed.ts",
    "db:seed-isaac": "npx --yes tsx scripts/seed-isaac-network.ts",
    "db:reset-admin": "npx --yes tsx scripts/db-reset-admin-password.ts",
    "db:promote-admin": "npx --yes tsx scripts/db-promote-admin.ts",
    "db:reset-direct-binary-pending": "npx --yes tsx scripts/db-reset-direct-binary-pending.ts",
