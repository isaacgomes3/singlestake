    "test:local": "npx --yes tsx scripts/test-local.ts",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "preview": "vite preview",
    "start": "node --import dotenv/config .output/server/index.mjs",
    "measure:nums28": "npx --yes tsx scripts/measure-nums28-tie-break.ts",
    "sim:nums28-hypo": "npx --yes tsx scripts/sim-nums28-no-gatilho-hypothetical.ts",
