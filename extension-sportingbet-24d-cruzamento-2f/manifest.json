{
  "manifest_version": 3,
  "name": "stake37 — Sportingbet 24D Cruzamento 2F",
  "version": "1.0.9",
  "description": "24D Spin · 9,5s · limpa indicação no resultado · gatilho 2×4 · mesa 3426.",
  "permissions": [
    "tabs",
    "storage",
    "scripting",
    "debugger",
    "windows"
  ],
  "host_permissions": [
    "https://www.sportingbet.bet.br/*",
    "https://sportingbet.bet.br/*",
    "https://*.br4.bet.br/*",
    "https://*.pragmaticplaylive.net/*",
    "https://*.pragmaticplay.net/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.sportingbet.bet.br/*",
        "https://sportingbet.bet.br/*",
        "https://*.br4.bet.br/*"
      ],
      "js": [
        "content-casino.js",
        "content-sportingbet24d2f-panel.js"
      ],
      "all_frames": false,
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.pragmaticplaylive.net/*",
        "https://*.pragmaticplay.net/*"
      ],
      "js": [
        "content-casino.js",
        "calibration-relay.js"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "stake37 Sportingbet 24D 2F — clica para abrir painel"
  }
}
