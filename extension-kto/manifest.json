{
  "manifest_version": 3,
  "name": "stake37 — KTO 2 Fatores",
  "version": "1.3.0",
  "description": "Cruzamento sequencial 2 fatores na Roulette 3 (KTO mesa 230). Gales alternados (oposto em 1,4,5).",
  "permissions": ["tabs", "storage", "scripting", "debugger", "windows"],
  "host_permissions": ["https://www.kto.bet.br/*", "https://kto.bet.br/*", "https://*.pragmaticplaylive.net/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.kto.bet.br/*", "https://kto.bet.br/*"],
      "js": ["content-casino.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "stake37 KTO",
    "default_popup": "popup.html"
  }
}
