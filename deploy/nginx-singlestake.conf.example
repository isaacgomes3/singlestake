# Nginx — reverse proxy para Singlestake (Node PM2 na porta 3000)
# 1. Copiar: sudo cp deploy/nginx-singlestake.conf.example /etc/nginx/sites-available/singlestake
# 2. Substituir SEU_DOMINIO pelo domínio real (ex. singlestake.bet.br)
# 3. sudo ln -sf /etc/nginx/sites-available/singlestake /etc/nginx/sites-enabled/
# 4. sudo nginx -t && sudo systemctl reload nginx
# 5. sudo certbot --nginx -d SEU_DOMINIO

map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

server {
    listen 80;
    server_name SEU_DOMINIO www.SEU_DOMINIO;

    # Redireccionar HTTP → HTTPS (activar depois do certbot)
    # return 301 https://$host$request_uri;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
        proxy_buffering off;
    }

    # SSE — roleta ao vivo e streams longos
    location ~ ^/api/(roulette/spins|roulette/strategy-global/stream|roulette/automation-sim/stream|pragmatic/) {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection '';
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
        proxy_buffering off;
        chunked_transfer_encoding off;
    }
}

