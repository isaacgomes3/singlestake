# Ambiente de automação — subdomínio (ex.: auto.stake37.com.br)
# Copiar na VPS: cp deploy/env.automation.example .env.automation
# PM2: processo `singlestake-automation` na porta 3001 (ver deploy/ecosystem.config.cjs)

NODE_ENV=production
PORT=3001
HOST=127.0.0.1
APP_PROFILE=automation

PUBLIC_APP_URL=https://auto.stake37.com.br
PUBLIC_AUTOMATION_URL=https://auto.stake37.com.br
VITE_AUTOMATION_PUBLIC_URL=https://auto.stake37.com.br

# Roleta ao vivo (Pragmatic DGA) — mesmo hub que produção
ROULETTE_WS_URL=wss://dga.pragmaticplaylive.net/ws
ROULETTE_CASINO_ID=ppcdk00000005148
ROULETTE_TABLE_IDS=234,227,203,230,201,206,237,213
ROULETTE_CURRENCY=BRL
ROULETTE_HUB_IDLE_SHUTDOWN_MS=-1

WS_NO_BUFFER_UTIL=1
WS_NO_UTF_8_VALIDATE=1

# Estado de automação isolado do back office (não partilhar com stake37.com.br)
ROULETTE_STRATEGY_GLOBAL_PATH=/var/www/stake37/data/automation/roulette-strategy-global.json
ROULETTE_AUTOMATION_SIM_PATH=/var/www/stake37/data/automation/roulette-automation-sim.json

# Auth partilhada (mesma BD) — login único com cookie .stake37.com.br
DATABASE_URL=/var/www/stake37/data/singlestake.db
SESSION_SECRET=MESMO_VALOR_DO_ENV_PRINCIPAL
SESSION_COOKIE_DOMAIN=.stake37.com.br

# Build-time (rebuild após alterar): VITE_CASINO_TABLE_EMBED_URLS=...
