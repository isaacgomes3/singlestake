# Produção — stake37.com.br
# Copiar na VPS: cp deploy/env.production.example .env
# Gerar SESSION_SECRET: openssl rand -hex 32

NODE_ENV=production
PORT=3000
HOST=127.0.0.1
PUBLIC_APP_URL=https://stake37.com.br
# Subdomínio de automação (sala rotativa, simulador, extensão) — isolado do back office
PUBLIC_AUTOMATION_URL=https://auto.stake37.com.br
VITE_AUTOMATION_PUBLIC_URL=https://auto.stake37.com.br
APP_PROFILE=backoffice

# Roleta ao vivo (Pragmatic DGA)
ROULETTE_WS_URL=wss://dga.pragmaticplaylive.net/ws
ROULETTE_CASINO_ID=ppcdk00000005148
ROULETTE_TABLE_IDS=234,227,203,230,201,206,237,213
ROULETTE_CURRENCY=BRL
# Manter WebSocket Pragmatic sempre activo (sem fechar por idle)
ROULETTE_HUB_IDLE_SHUTDOWN_MS=-1

# Evita crash do `ws` quando bufferutil nativo não está disponível / bundle quebrado
WS_NO_BUFFER_UTIL=1
WS_NO_UTF_8_VALIDATE=1

# Base de dados SQLite na VPS
DATABASE_URL=/var/www/stake37/data/singlestake.db
SESSION_SECRET=SUBSTITUIR_POR_STRING_ALEATORIA_LONGA
# Cookie partilhado entre stake37.com.br e www.stake37.com.br
SESSION_COOKIE_DOMAIN=.stake37.com.br

# Admin inicial (só usado em npm run db:seed com FIRST_DEPLOY=1)
SEED_ADMIN_EMAIL=admin@stake37.com.br
SEED_ADMIN_PASSWORD=ALTERAR_SENHA_FORTE

# URLs do operador (br4.bet Pragmatic) — já vêm no código; opcional sobrescrever no build:
# VITE_CASINO_TABLE_EMBED_URLS={"237":"https://br4.bet.br/play/pragmatic/roleta-brasileira",...}

# Efi Pay — PIX dinâmico (valor exacto por pacote; requer certificado .p12)
EFI_PIX_CLIENT_ID=
EFI_PIX_CLIENT_SECRET=
EFI_PIX_KEY=
EFI_PIX_CERT_PATH=/var/www/stake37/data/efi-cert.p12
EFI_PIX_CERT_PASSPHRASE=
EFI_PIX_SANDBOX=false

# Pix copia e cola fixo — gera QR sem API (Bradesco/Poupex/etc.)
# Um código por valor; confirmação manual no back office (modo static).
PIX_COPIA_COLA_50=00020101021226860014BR.GOV.BCB.PIX2564qrpix.bradesco.com.br/qr/v2/acdb01aa-1a10-4dda-86fb-ba834d788b27520400005303986540550.005802BR5911POUPEX LTDA6008SALVADOR62070503***6304C9BB
PIX_COPIA_COLA_250=00020101021226860014BR.GOV.BCB.PIX2564qrpix.bradesco.com.br/qr/v2/46f9fdc3-8953-4013-90aa-b298717033065204000053039865406250.005802BR5911POUPEX LTDA6008SALVADOR62070503***63049892
# Legado — um único código (opcional)
# PIX_COPIA_COLA=
